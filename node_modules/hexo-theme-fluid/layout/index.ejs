<!-- 临时声明：用于 js.org 审核 -->
<div style="
    background: linear-gradient(135deg, #e6f3ff 0%, #d4e9ff 100%);
    color: #2c3e50;
    text-align: center;
    padding: 12px 20px;
    margin-bottom: 25px;
    border-radius: 40px;
    border: 1px solid #9ac0ff;
    box-shadow: 0 2px 10px rgba(66,153,225,0.2);
    font-size: 0.95rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
">
    🌟 本站基于 <strong>Node.js/Hexo</strong> 构建，前端交互深度定制（点赞、排序、瀑布流） · 
    与 JavaScript 生态紧密相关
</div>

<%
if (theme.index.slogan.enable) {
  page.subtitle = theme.index.slogan.text || config.subtitle || '';
}
page.banner_img = theme.index.banner_img;
page.banner_img_height = theme.index.banner_img_height;
page.banner_mask_alpha = theme.index.banner_mask_alpha;
%>

<% page.posts.each(function (post) { %>
  <div class="row mx-auto index-card">
    <% var post_url = url_for(post.path); %>
    <% var index_img = post.index_img || theme.post.default_index_img; %>
    
    <% if (index_img) { %>
      <div class="col-12 col-md-4 m-auto index-img">
        <a href="<%= post_url %>" target="<%= theme.index.post_url_target %>">
          <img src="<%= url_for(index_img) %>" alt="<%= post.title %>">
        </a>
      </div>
    <% } %>
    
    <article class="col-12 col-md-<%= index_img ? '8' : '12' %> mx-auto index-info">
      <h2 class="index-header">
        <% if (theme.index.post_sticky && theme.index.post_sticky.enable && post.sticky > 0) { %>
          <i class="index-pin <%= theme.index.post_sticky.icon %>" title="Pin on top"></i>
        <% } %>
        <a href="<%= post_url %>" target="<%= theme.index.post_url_target %>">
          <%= post.title %>
        </a>
      </h2>

      <!-- 摘要部分（已隐藏） -->
      <div style="display:none;"></div>

      <!-- 卡片底部元数据 -->
      <div class="index-btm post-metas">
        <!-- 第一行：日期 + 分类 -->
        <div class="meta-row">
          <% if (theme.index.post_meta.date) { %>
            <div class="post-meta">
              <i class="iconfont icon-date"></i>
              <time datetime="<%= full_date(post.date, 'YYYY-MM-DD HH:mm') %>" pubdate>
                <%= date(post.date, config.date_format) %>
              </time>
            </div>
          <% } %>
          
          <% if (theme.index.post_meta.category && post.categories.length > 0) { %>
            <div class="post-meta">
              <i class="iconfont icon-category"></i>
              <%- partial('_partials/category-chains', { categories: post.categories, limit: 1 }) %>
            </div>
          <% } %>
        </div>

        <!-- 第二行：阅读数 + 点赞（在同一行） -->
        <div class="meta-row" style="display: flex; flex-wrap: wrap; align-items: center; gap: 1rem;">
          <!-- 阅读数 -->
          <div class="post-meta">
            <i class="iconfont icon-eye" style="color: var(--blue-cloud);"></i>
            <span class="view-count" data-url="<%= post.permalink %>" style="color: var(--blue-cloud); font-weight: 500;">0</span>阅读
          </div>
          
          <!-- 点赞数（跟在阅读数后面） -->
          <div class="post-meta like-display" style="display: inline-flex; align-items: center; gap: 0.2rem;">
            <span style="color: var(--blue-cloud); font-size: 0.9rem;">❤️</span>
            <span class="like-count" style="color: var(--blue-cloud); font-weight: 500;">0</span>
          </div>
        </div>
      </div>
    </article>
  </div>
<% }) %>

<%- partial('_partials/paginator') %>